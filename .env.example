# =============================================================
# Speediance AI 私教智能体 - 环境变量示例
# 复制为 .env 后填写真实值
# =============================================================

# ── 应用基础 ─────────────────────────────────────────────────
APP_ENV=development                         # development | production | testing
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=change-me-to-a-random-secret-key-32chars

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=fitness_agent
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_pg_password
# 连接池
POSTGRES_POOL_SIZE=10
POSTGRES_MAX_OVERFLOW=20

# ── Redis ─────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=                             # 留空表示无密码
REDIS_DB=0
REDIS_TTL_SECONDS=3600                      # 短期记忆默认 TTL（秒）
REDIS_MAX_SHORT_TERM_MESSAGES=20            # 短期记忆保留最近 N 条消息

# ── 通义千问 / DashScope (OpenAI 兼容接口) ─────────────────────
DASHSCOPE_API_KEY=sk-your-dashscope-api-key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 主力模型（推理、生成）
QWEN_PLUS_MODEL=qwen-plus
# 轻量模型（query rewrite、分类）
QWEN_TURBO_MODEL=qwen-turbo
# 向量模型
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIMENSIONS=1536
# 重排序模型
RERANK_MODEL=gte-rerank

# 模型参数
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096
LLM_REQUEST_TIMEOUT=60

# ── App 后端接口 ───────────────────────────────────────────────
APP_BACKEND_BASE_URL=https://api.speediance.com
APP_BACKEND_API_KEY=your-internal-api-key
APP_BACKEND_TIMEOUT=10
APP_BACKEND_MAX_RETRIES=3

# ── RAG 参数 ──────────────────────────────────────────────────
RAG_TOP_K=10                                # 初检召回数量
RAG_RERANK_TOP_N=5                          # 重排后保留数量
RAG_MIN_SCORE=0.6                           # 最低相似度阈值

# ── 会话摘要 ──────────────────────────────────────────────────
SUMMARIZE_AFTER_MESSAGES=20                 # 每 N 条消息触发一次摘要

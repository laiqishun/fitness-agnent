# =============================================================
# Speediance AI 私教智能体 - 环境变量
# =============================================================

# ── 应用基础 ─────────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=speediance-dev-secret-key-change-in-prod

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=fitness_agent
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_POOL_SIZE=10
POSTGRES_MAX_OVERFLOW=20

# ── Redis ─────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL_SECONDS=3600
REDIS_MAX_SHORT_TERM_MESSAGES=20

# ── 通义千问 / DashScope ──────────────────────────────────────
DASHSCOPE_API_KEY=sk-placeholder
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_PLUS_MODEL=qwen-plus
QWEN_TURBO_MODEL=qwen-turbo
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIMENSIONS=1536
RERANK_MODEL=gte-rerank
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096
LLM_REQUEST_TIMEOUT=60

# ── App 后端接口 ───────────────────────────────────────────────
APP_BACKEND_BASE_URL=https://api.speediance.com
APP_BACKEND_API_KEY=placeholder
APP_BACKEND_TIMEOUT=10
APP_BACKEND_MAX_RETRIES=3

# ── RAG 参数 ──────────────────────────────────────────────────
RAG_TOP_K=10
RAG_RERANK_TOP_N=5
RAG_MIN_SCORE=0.6

# ── 会话摘要 ──────────────────────────────────────────────────
SUMMARIZE_AFTER_MESSAGES=20
